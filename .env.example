# ── Email (Contact / Quote / Booking API → Nodemailer) ─────────────────────
# Required on Vercel: Project → Settings → Environment Variables → Production (and Preview if you test there)
# After saving variables, trigger a new Deployment (Redeploy).
#
# Gmail (recommended for testing):
# 1. Use a Google account (e.g. cmdourcar@gmail.com).
# 2. Enable 2-Step Verification: https://myaccount.google.com/security
# 3. Create an App Password: Google Account → Security → App passwords → Mail / Other → copy 16-char password.
# 4. Set:
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="cmdourcar@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
# Where lead/quote/booking notifications are delivered (can be same as SMTP_USER):
NOTIFY_EMAIL="cmdourcar@gmail.com"

# Site URL
NEXT_PUBLIC_SITE_URL="https://www.3mourcar.com"

# WhatsApp number (without + prefix)
NEXT_PUBLIC_WHATSAPP="971XXXXXXXXX"
NEXT_PUBLIC_PHONE="+971-XX-XXX-XXXX"
